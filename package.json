{
  "name": "acr-agent-helper",
  "version": "1.1.0",
  "description": "实时代码展示桌面工具 — 接收 AI Agent 推送的代码，实时分析并展示",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.agent-code-reporter",
    "productName": "Vbcoding代码助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "mcp-server.js",
      "analyzer.js",
      "renderer/**/*",
      "icon.*",
      "config.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/tree-sitter-wasm/out",
        "to": "tree-sitter-wasm",
        "filter": [
          "*.wasm"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ACR代码助手"
    }
  },
  "dependencies": {
    "tree-sitter-wasm": "^1.0.5",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.34.5"
  }
}
